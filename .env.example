# --- IMAP ---
EXCHANGE_IMAP_HOST=outlook.office365.com
EXCHANGE_IMAP_PORT=993

# --- SMTP ---
EXCHANGE_SMTP_HOST=smtp.office365.com
EXCHANGE_SMTP_PORT=587

# --- Serveur HTTP ---
# Port expose sur l'hote
EXCHANGE_MCP_SSE_PORT=3000

# URL publique (derriere un reverse proxy). Laisser vide pour http://localhost:<port>
EXCHANGE_MCP_ISSUER=

# --- Logging ---
RUST_LOG=info
